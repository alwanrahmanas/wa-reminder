# ============================================
# BPS WA Reminder - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# OpenAI API Key (required for natural language messages)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI Model (default: gpt-4o-mini for cost efficiency)
OPENAI_MODEL=gpt-4o-mini

# Schedule Configuration
# Cron format: second minute hour dayOfMonth month dayOfWeek
# Default: Every day at 07:00 and 19:00
SCHEDULE_MORNING=0 0 7 * * *
SCHEDULE_EVENING=0 0 19 * * *

# Weekly digest: Every Monday at 08:00
SCHEDULE_WEEKLY=0 0 8 * * 1

# Timezone
TZ=Asia/Makassar
